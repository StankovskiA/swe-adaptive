FROM python:3.8-slim
WORKDIR /root/code
RUN apt-get update && apt-get install -y --no-install-recommends build-essential glpk-utils && rm -rf /var/lib/apt/lists/*
COPY . .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -r requirements.txt \
 && pip install --no-cache-dir "PuLP>=2.0" \
 && pip install --no-cache-dir -e . \
 && pip install --no-cache-dir pytest
CMD ["pytest", "tests/unit/", "-v", "--ignore=tests/unit/test_distribution_ilp_compref.py", "--ignore=tests/unit/test_algorithms_ncbb.py"]
