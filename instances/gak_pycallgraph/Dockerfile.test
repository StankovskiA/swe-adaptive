FROM python:3.8-slim
WORKDIR /root/code
RUN apt-get update && apt-get install -y --no-install-recommends build-essential graphviz && rm -rf /var/lib/apt/lists/*
COPY . .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -e . \
 && pip install --no-cache-dir pytest
RUN sed -i 's/\.iteritems()/.items()/g' \
    pycallgraph/output/output.py \
    pycallgraph/config.py \
    pycallgraph/tracer.py \
    pycallgraph/output/graphviz.py
CMD ["pytest", "test/", "-v", "--ignore=test/test_decorators.py", "--ignore=test/test_script.py"]
