FROM python:3.7-slim
WORKDIR /root/code
RUN apt-get update && apt-get install -y --no-install-recommends build-essential redis-server && rm -rf /var/lib/apt/lists/*
COPY . .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -r requirements.txt \
 && pip install --no-cache-dir mock \
 && pip install --no-cache-dir -e . \
 && pip install --no-cache-dir pytest
# strip [nosetests] section: requires coverage plugins not installed
RUN printf '[wheel]\nuniversal=1\n' > setup.cfg
# pytest doesn't support --python-classes CLI flag; use ini config instead
RUN printf '[pytest]\npython_classes = *Tests\npython_files = *_tests.py\n' > pytest.ini
# cluster/failover/migration tests require multi-node Redis setup; excluded
# cluster/failover/migration tests require multi-node Redis; on_close_callback_invoked fails due to Redis version CLIENT KILL syntax change
CMD ["sh", "-c", "redis-server --daemonize yes && sleep 0.5 && pytest tests/ -v --ignore=tests/cluster_behavior_tests.py --ignore=tests/cluster_tests.py --ignore=tests/failover_tests.py -k 'not MigrationTests and not test_on_close_callback_invoked'"]
