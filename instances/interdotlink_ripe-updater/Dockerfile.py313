FROM python:3.13-slim

WORKDIR /root/code

COPY . .

# werkzeug pin carried over from baseline (pre-existing issue unrelated to Python version)
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir \
      -r requirements.txt \
      "werkzeug<3.0" \
      -r test-requirements.txt \
 && pip install --no-cache-dir -e .

RUN pytest tests/ -v
