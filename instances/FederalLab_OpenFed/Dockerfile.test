FROM python:3.8-slim
WORKDIR /root/code
RUN apt-get update && apt-get install -y --no-install-recommends build-essential && rm -rf /var/lib/apt/lists/*
COPY . .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -r requirements.txt -r requirements/test.txt \
 && pip install --no-cache-dir -e . \
 && pip install --no-cache-dir pytest \
 && pip install --no-cache-dir torchvision \
 && pip install --no-cache-dir "protobuf<3.21" "numpy<1.24" pytest-timeout
CMD ["pytest", "tests/", "-v", "--timeout=60", "--ignore=tests/test_simulator.py", "--ignore=tests/test_paillier_crypto.py", "--ignore=tests/test_federated", "--ignore=tests/test_core/test_maintainer.py"]
