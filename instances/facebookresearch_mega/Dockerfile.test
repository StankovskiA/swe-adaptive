FROM python:3.7-slim
WORKDIR /root/code
RUN find /etc/apt -name "*.list" -exec sed -i 's|deb.debian.org|archive.debian.org|g; s|security.debian.org|archive.debian.org|g; /stretch-updates/d' {} \; \
 && apt-get update && apt-get install -y --no-install-recommends build-essential && rm -rf /var/lib/apt/lists/*
COPY . .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -e . \
 && pip install --no-cache-dir pytest scikit-learn
CMD ["pytest", "tests/", "-v", "--ignore=tests/test_convtbc.py", "--ignore=tests/speech_recognition", "--ignore=tests/test_binaries.py", "--ignore=tests/test_reproducibility.py", "--ignore=tests/test_token_block_mixture_dataset.py"]
