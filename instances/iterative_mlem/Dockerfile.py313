FROM python:3.13-slim

RUN apt-get update && apt-get install -y gcc git && rm -rf /var/lib/apt/lists/*

COPY ./ /root/code
WORKDIR /root/code

RUN pip install --upgrade pip

# Attempt a plain install on Python 3.13 with no workarounds.
# Expected to fail or produce a broken environment.
RUN pip install -e "."

RUN python -c "import mlem; print('import OK')"
