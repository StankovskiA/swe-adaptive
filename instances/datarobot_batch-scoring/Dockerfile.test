FROM python:3.7-slim
WORKDIR /root/code
RUN apt-get update && apt-get install -y --no-install-recommends build-essential && rm -rf /var/lib/apt/lists/*
COPY . .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -e . \
 && pip install --no-cache-dir \
      "pytest>=3.0,<6.2" \
      "Flask<2.0" \
      "Werkzeug<2.0" \
      "MarkupSafe<2.0" \
      "mock>=1.3.0"
# test_parse_host_success: calls a fixture directly (pytest 2.x allowed this, pytest 6+ does not)
# test_quotechar_in_keep_cols: pre-existing logic bug unrelated to Python version compatibility
CMD ["pytest", "tests/", "-v", \
     "-k", "not test_parse_host_success and not test_quotechar_in_keep_cols"]
