FROM python:3.10-slim

WORKDIR /root/code

COPY . .

RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir \
      "Django>=3.2,<4.0" \
      "pydantic>=1.8.2,<2.0" \
      pytest \
      pytest-django \
      factory-boy \
      psycopg2-binary \
 && pip install --no-cache-dir -e .

CMD ["pytest", "tests/", "-q"]
