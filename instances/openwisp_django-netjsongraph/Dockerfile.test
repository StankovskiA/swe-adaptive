FROM python:3.7-slim
WORKDIR /root/code
RUN apt-get update && apt-get install -y --no-install-recommends build-essential && rm -rf /var/lib/apt/lists/*
COPY . .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -r requirements.txt -r requirements-test.txt \
 && pip install --no-cache-dir -e . \
 && pip install --no-cache-dir pytest pytest-django
RUN printf '[pytest]\nDJANGO_SETTINGS_MODULE = settings\n' > pytest.ini
ENV PYTHONPATH=/root/code/tests
# ignore tests/base/ and filter -k "not Mixin": base/ contains abstract mixin classes not meant to run directly;
# concrete test files import mixins into their namespace, so -k "not Mixin" is needed to skip them
CMD ["pytest", "django_netjsongraph/tests/", "-v", "--ignore=django_netjsongraph/tests/base/", "-k", "not Mixin"]
