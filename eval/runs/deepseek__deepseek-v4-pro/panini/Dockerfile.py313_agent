FROM python:3.13-slim

WORKDIR /app

# Install NATS server
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    curl -L -o /tmp/nats-server.tar.gz https://github.com/nats-io/nats-server/releases/download/v2.10.18/nats-server-v2.10.18-linux-amd64.tar.gz && \
    tar xzf /tmp/nats-server.tar.gz -C /tmp && \
    mv /tmp/nats-server-v2.10.18-linux-amd64/nats-server /usr/local/bin/ && \
    rm -rf /tmp/nats-server* && \
    apt-get remove -y curl && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

COPY . /app

RUN pip install -r requirements/defaults.txt
RUN pip install -e .

# Start NATS server in background and run tests
RUN nats-server -p 4222 & \
    sleep 2 && \
    python -m pytest tests/ -q
