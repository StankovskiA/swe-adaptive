+def _get_additional_special_tokens(tokenizer):
+    """Get list of additional special tokens, compatible with old and new transformers."""
+    if hasattr(tokenizer, 'additional_special_tokens'):
+        return tokenizer.additional_special_tokens
+    # Newer transformers (>=5.x) store additional special tokens in _extra_special_tokens
+    if hasattr(tokenizer, '_extra_special_tokens'):
+        return [str(t) for t in tokenizer._extra_special_tokens]
+    return []
+
+
+def _get_additional_special_tokens_ids(tokenizer):
+    """Get list of additional special token ids, compatible with old and new transformers."""
+    if hasattr(tokenizer, 'additional_special_tokens_ids'):
+        return tokenizer.additional_special_tokens_ids
+    # Newer transformers (>=5.x): compute from _extra_special_tokens
+    if hasattr(tokenizer, '_extra_special_tokens'):
+        return tokenizer.convert_tokens_to_ids(
+            [str(t) for t in tokenizer._extra_special_tokens]
+        )
+    return []
+
+
 @dataclass(frozen=True)
