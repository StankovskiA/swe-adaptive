@@ -15,6 +15,31 @@ from seleniumwire.thirdparty.mitmproxy.utils import typecheck
     The base implementation for Options.
 """
 
+
+def _safe_ref(target):
+    """Create a safe reference to a callable.
+    
+    For bound methods, creates a weakref to the instance and returns
+    a callable that reconstructs the method or returns None if the
+    instance was garbage collected.
+    For other callables, uses weakref.ref directly.
+    """
+    if hasattr(target, '__self__') and hasattr(target, '__func__'):
+        # Bound method
+        ref = weakref.ref(target.__self__)
+        func_name = target.__func__.__name__
+        def _ref():
+            obj = ref()
+            if obj is None:
+                return None
+            return getattr(obj, func_name, None)
+        return _ref
+    else:
+        ref = weakref.ref(target)
+        def _ref():
+            return ref()
+        return _ref
+
 unset = object()
 
 
@@ -135,7 +160,7 @@ class OptManager:
 
         # We reuse blinker's safe reference functionality to cope with weakrefs
         # to bound methods.
-        func = blinker._saferef.safe_ref(func)
+        func = _safe_ref(func)
 
         @functools.wraps(func)
         def _call(options, updated):
