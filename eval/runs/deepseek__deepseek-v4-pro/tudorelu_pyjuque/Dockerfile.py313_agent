FROM python:3.13-slim

WORKDIR /app

COPY . /app

# Install dependencies
RUN pip install --upgrade pip setuptools wheel

# Install the package in editable mode (uses setup.py with fixed pyyaml version)
RUN pip install -e .

# Install test dependencies
RUN pip install pytest alchemy-mock==0.4.3 coverage==5.1 freezegun==0.3.15 mock==4.0.2 nose2==0.9.2

# Run tests
RUN python -m pytest tests/ -v
