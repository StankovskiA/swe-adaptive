@@ -0,0 +1,19 @@
+FROM python:3.13-slim
+
+WORKDIR /app
+
+# Install system build dependencies needed for some packages
+RUN apt-get update && apt-get install -y --no-install-recommends \
+    gcc \
+    libc6-dev \
+    && rm -rf /var/lib/apt/lists/*
+
+# Copy project files
+COPY . /app
+
+# Install the project and all dependencies (using requirements.txt which has been updated for Python 3.13)
+RUN pip install --no-cache-dir -r requirements.txt
+
+# Run the full test suite (using SQLite as the test database)
+ENV TEST_DATABASE_URLS="sqlite:///test.db"
+RUN python -m pytest tests/ -v
