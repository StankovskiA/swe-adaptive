+def _match_hostname(cert, hostname):
+    """
+    Match a hostname against a certificate structure, similar to the removed
+    :func:`ssl.match_hostname` function.
+    """
+    import ipaddress
+
+    def _hostname_match(hostname, pattern):
+        if not pattern:
+            return False
+        hostname = hostname.lower()
+        pattern = pattern.lower()
+        if '*' not in pattern:
+            return hostname == pattern
+        if pattern.startswith('*.'):
+            if pattern.count('.') < 1:
+                return False
+            pattern_suffix = pattern[2:]
+            if not hostname.endswith(pattern_suffix):
+                return False
+            hostname_prefix = hostname[:-len(pattern_suffix)]
+            if not hostname_prefix or hostname_prefix == '.':
+                return False
+            if hostname.count('.') != pattern.count('.'):
+                return False
+            return True
+        import fnmatch
+        return fnmatch.fnmatch(hostname, pattern)
+
+    san = cert.get('subjectAltName', ())
+    for key, value in san:
+        if key == 'DNS':
+            if _hostname_match(hostname, value):
+                return
+        elif key == 'IP Address':
+            try:
+                ip_addr = ipaddress.ip_address(hostname)
+                if ip_addr == ipaddress.ip_address(value):
+                    return
+            except ValueError:
+                pass
+    subject = cert.get('subject', ())
+    for rdns in subject:
+        for key, value in rdns:
+            if key.lower() in ('commonname', 'cn'):
+                if _hostname_match(hostname, value):
+                    return
+    raise ssl.CertificateError(
+        "hostname %r doesn't match certificate" % hostname
+    )
+
+
 def check_x509_hostname(x509, hostname):
