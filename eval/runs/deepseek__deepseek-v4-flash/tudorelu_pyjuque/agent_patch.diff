diff --git a/Dockerfile.py313 b/Dockerfile.py313
new file mode 100644
index 0000000..6a92173
--- /dev/null
+++ b/Dockerfile.py313
@@ -0,0 +1,22 @@
+FROM python:3.13-slim
+
+WORKDIR /app
+
+# Install system dependencies needed for building some packages
+RUN apt-get update && apt-get install -y --no-install-recommends \
+    gcc \
+    && rm -rf /var/lib/apt/lists/*
+
+COPY . /app
+
+# Upgrade pip, setuptools, wheel
+RUN pip install --upgrade pip setuptools wheel
+
+# Install the project and all its dependencies
+RUN pip install -e .
+
+# Install test dependencies
+RUN pip install "alchemy-mock==0.4.3" "coverage==5.1" "freezegun==0.3.15" "mock==4.0.2" "nose2==0.9.2"
+
+# Run the full test suite
+RUN python -m unittest discover -s tests -v
