FROM python:3.13-slim

# Install system dependencies needed for compiling python packages with C extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy setup and requirements files first to leverage Docker's build cache
COPY requirements.txt requirements-dev.txt pyproject.toml setup.py setup.cfg README.md LICENSE /app/

# Upgrade build tools and install the package dependencies
RUN pip install --no-cache-dir --upgrade pip setuptools wheel
RUN pip install --no-cache-dir -r requirements.txt -r requirements-dev.txt

# Copy the rest of the application files
COPY . /app

# Install the application itself in editable mode
RUN pip install --no-cache-dir -e .

# Run the test suite so that any test failures cause the docker build to fail
RUN python -m pytest
